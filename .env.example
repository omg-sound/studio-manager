# ── 녹음실 관리 앱 환경변수 카탈로그 ──
# 복사: cp .env.example .env  후 값 채우기

# 관리자(스튜디오 owner) Google 이메일 — 이 이메일로 OAuth 로그인해야 admin 권한 부여
ADMIN_EMAIL=studio@example.com

# JWT 서명 시크릿(세션 쿠키 서명). 길고 무작위한 값.
#   생성 예: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me-long-random

# AES-256-GCM 키 파생용(refresh token 등 비밀 at-rest 암호화). 무작위 값.
TOKEN_ENC_KEY=change-me-another-long-random

# ── Google OAuth (관리자 로그인 + Drive 스토리지 구동) ──
# Google Cloud Console > OAuth 클라이언트(웹). redirect URI = {BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 외부 베이스 URL. 로컬은 http://localhost:3000.
# Render 배포 시 RENDER_EXTERNAL_URL이 자동 주입되면 그 값을 우선 사용한다.
BASE_URL=http://localhost:3000

# 서버 포트
PORT=3000

# SQLite 파일 경로
DB_PATH=./data/app.db

# 업로드 최대 크기(MB) — 자료 전달 단계에서 사용
MAX_UPLOAD_MB=200

# ── 개발 전용 ──
# OAuth 자격증명 없이 로컬에서 로그인 검증할 때 사용. 프로덕션에서는 반드시 비활성(빈 값).
#   DEV_LOGIN=1  → /dev-login 라우트 활성화
DEV_LOGIN=

# ── cron(일일 백업 + 연체 스캔) ──
# 내부 트리거 라우트 POST /internal/cron/daily 의 인증 토큰. 설정하면 그 라우트가 활성화된다.
# 미설정 시 라우트는 404(비활성). 프로덕션은 web·cron 두 서비스에 동일한 강한 값을 넣는다.
#   생성 예: openssl rand -hex 32
BACKUP_TOKEN=

# (cron 서비스 전용) web 서비스 트리거 URL 직접 지정(선택). 로컬 테스트나 외부 URL 강제 시.
# 미설정 시 WEB_HOSTPORT(Render 주입) → http://localhost:3000 순으로 폴백.
#   예: CRON_TRIGGER_URL=https://your-app.onrender.com/internal/cron/daily
CRON_TRIGGER_URL=
